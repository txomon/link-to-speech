# Required
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
OPENAI_API_KEY=your_openai_api_key

# Comma-separated Telegram user IDs allowed to use the bot (empty = allow all)
ALLOWED_USER_IDS=

# Default Telegram chat ID for addon requests (get yours via /start command)
DEFAULT_CHAT_ID=

# TTS settings
TTS_VOICE=alloy
TTS_MODEL=tts-1

# Shared secret for authenticating Firefox addon requests (optional)
SERVER_SECRET=

# HTTP listen address for the addon API
LISTEN_ADDR=:8080
