{
  "manifest_version": 2,
  "name": "Article to Audio",
  "version": "1.0",
  "description": "Extract article text and send to TTS backend for Telegram delivery",
  "permissions": [
    "activeTab",
    "storage",
    "notifications"
  ],
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Send article to audio"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "options_ui": {
    "page": "options.html"
  }
}
